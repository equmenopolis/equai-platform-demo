# Bearer token used by this demo to call the EQU AI Platform.
EQU_AI_PLATFORM_API_KEY=

# Public base URL for this Next app. Webhook registration appends /api/webhook.
# Leave blank if you run `pnpm dev:tunnel` — the script sets this from
# cloudflared's published URL. Required only for plain `pnpm dev` against a
# self-managed tunnel, or for production deploys.
# Example: https://your-public-host.example.com
WEBHOOK_BASE_URL=

# Optional. Shared secret registered with EQU and checked on inbound webhooks.
# Leave blank to generate a per-process secret on startup.
WEBHOOK_SECRET=
